# Local demo defaults
VITE_DEMO_MODE=true
VITE_DATA_MODE=demo
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_MAP_PROVIDER=demo
VITE_KAKAO_JAVASCRIPT_KEY=

# Media limits
VITE_ENABLE_VIDEO_UPLOAD=true
VITE_MAX_VIDEO_SECONDS=15
VITE_MAX_VIDEO_BYTES=52428800
VITE_MAX_IMAGE_BYTES=10485760

# Development-only React tools stay disabled in production builds when set to 1.
VITE_DISABLE_REACT_DEVTOOLS=0
